# Frontend Production Configuration (Vercel)
# Copy these values to Vercel Settings -> Environment Variables

# Backend URL (Railway)
# REPLACE WITH YOUR ACTUAL RAILWAY URL
NEXT_PUBLIC_API_URL=[YOUR_RAILWAY_URL]

# Edge Node URL (Ngrok)
NEXT_PUBLIC_SCANNER_URL=https://ugsome-saltless-robbyn.ngrok-free.app
NEXT_PUBLIC_SCANNER_PORT=80

# API Key (Must match Edge Node)
NEXT_PUBLIC_KIOSK_API_KEY=thesis_kiosk_secure_key_2025

# Environment
NODE_ENV=production
